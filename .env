POSTGRES_DB=shop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio123
MINIO_REGION=us-east-1
MINIO_BROWSER=on

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minio123
MINIO_SECURE=false
MINIO_REGION=us-east-1

shop.minio.bucket=shop-images
shop.minio.endpoint=http://minio:9000
shop.minio.access-key=minioadmin
shop.minio.secret-key=minio123

REDIS_ENDPOINT=redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_ADDR=redis:6379
REDIS_URL=redis://redis:6379


SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/shop
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_JPA_DATABASE=postgresql
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

ETCD_ENDPOINT=etcd:2379
ETCD_HOST=etcd
ETCD_PORT=2379
